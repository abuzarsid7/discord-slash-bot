# Discord App & Bot Authentication
DISCORD_PUBLIC_KEY=your_discord_public_key
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APP_ID=your_discord_app_id
DISCORD_GUILD_ID=your_discord_dev_guild_id

# Database Connection (Neon Serverless Postgres / Prisma)
DATABASE_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# Downstream Mirror Webhooks (Slack Incoming Webhook or Discord Channel Webhook)
DISCORD_WEBHOOK_URL=your_default_discord_mirror_webhook_url
SLACK_WEBHOOK_URL=your_default_slack_mirror_webhook_url

# Free-Tier AI LLM Triage Keys (Optional: Simulation fallback used if empty)
GEMINI_API_KEY=your_free_google_gemini_api_key
GROQ_API_KEY=your_free_groq_api_key

# Admin Dashboard Login Credentials (Optional: Defaults to admin/admin123 in dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123